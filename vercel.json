{
  "buildCommand": "echo 'Static site'",
  "outputDirectory": ".",
  "installCommand": "echo 'No dependencies'",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/hwagok",
      "destination": "/hwagok.html"
    },
    {
      "source": "/magok",
      "destination": "/magok.html"
    },
    {
      "source": "/balsan",
      "destination": "/balsan.html"
    }
  ]
}
